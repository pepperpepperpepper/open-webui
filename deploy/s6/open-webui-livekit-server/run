#!/bin/sh
set -eu

cd /var/www/open-webui

export HOME=/home/arch
export TMPDIR=/home/arch/tmp/open-webui-livekit-server-runtime

# Base env (provider keys, etc.)
set -a
. /var/www/open-webui/.env

# LiveKit URL + credentials (generated by deploy/livekit/setup_self_hosted.py)
if [ -f /var/www/open-webui/deploy/livekit/livekit.env ]; then
  . /var/www/open-webui/deploy/livekit/livekit.env
fi
set +a

exec /usr/bin/s6-setuidgid pepper \
  /usr/local/bin/livekit-server --config /var/www/open-webui/deploy/livekit/livekit.yaml

